{
  "manifest_version": 3,
  "name": "Trợ lý Nhận xét Pro",
  "version": "1.0.4",
  "description": "Tiện ích mở rộng giúp giáo viên tự động điền nhận xét điểm thường xuyên và học bạ",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.csdl.moet.gov.vn/*",
    "*://*.vnedu.vn/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mở Trợ lý"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
